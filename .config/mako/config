# Gruvbox Light Mako Theme
max-history=100
sort=-time

# Colors and Style
background-color=#fbf1c7
text-color=#3c3836
border-color=#d5c4a1
border-size=2
border-radius=0
progress-color=source #b57614

# Typography
font=monospace 10

# Padding and Margin
padding=15
margin=10

[urgency=low]
border-color=#d5c4a1
default-timeout=5000

[urgency=normal]
border-color=#458588
default-timeout=10000

[urgency=critical]
background-color=#f9f5d7
text-color=#9d0006
border-color=#9d0006
default-timeout=0
